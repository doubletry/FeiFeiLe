# 海南航空账户配置（必填）
HNA_USERNAME=13800000000          # 会员手机号 / 登录账号
HNA_PASSWORD=your_password_here   # 账户密码

# 企业微信应用配置（非 dry-run 模式必填）
WECOM_CORP_ID=ww1234567890abcdef           # 企业 ID
WECOM_SECRET=your_app_secret_here          # 应用 Secret
WECOM_AGENT_ID=1000002                     # 应用 AgentId

# 监控配置（可选，以下为默认值）
MONITOR_PRICE_THRESHOLD=199       # 触发通知的最高票价（元）
MONITOR_SUBSCRIPTIONS_FILE=subscriptions.json   # 订阅列表文件路径

# 高级配置（通常不需要修改）
HNA_APP_VERSION=10.12.0            # 模拟的 App 版本号
HNA_DEVICE_ID=feifeile-monitor-001
HNA_BASE_URL=https://app.hnair.com
HNA_TIMEOUT=60.0
HNA_MAX_RETRIES=3
