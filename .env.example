# 海南航空账户配置（必填）
HNA_USERNAME=13800000000          # 会员手机号 / 登录账号
HNA_PASSWORD=your_password_here   # 账户密码

# 企业微信群机器人配置（必填）
# 在企业微信群里添加机器人后，复制 Webhook URL 填入此处
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY_HERE

# 监控配置（可选，以下为默认值）
MONITOR_PRICE_THRESHOLD=199       # 触发通知的最高票价（元）
MONITOR_INTERVAL_HOURS=4          # 两次查询的间隔（小时）
MONITOR_SUBSCRIPTIONS_FILE=subscriptions.json   # 订阅列表文件路径

# 高级配置（通常不需要修改）
HNA_APP_VERSION=7.8.0             # 模拟的 App 版本号
HNA_DEVICE_ID=feifeile-monitor-001
HNA_BASE_URL=https://appjis.hnair.com
HNA_TIMEOUT=60.0
HNA_MAX_RETRIES=3
